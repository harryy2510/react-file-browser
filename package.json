{
  "name": "react-file-browser",
  "version": "0.0.0-development",
  "description": "A standalone, storage-agnostic React file manager component library.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters/in-memory": {
      "types": "./dist/adapters/in-memory/index.d.ts",
      "import": "./dist/adapters/in-memory/index.js"
    },
    "./adapters/s3": {
      "types": "./dist/adapters/s3/index.d.ts",
      "import": "./dist/adapters/s3/index.js"
    },
    "./adapters/r2": {
      "types": "./dist/adapters/r2/index.d.ts",
      "import": "./dist/adapters/r2/index.js"
    },
    "./adapters/supabase": {
      "types": "./dist/adapters/supabase/index.d.ts",
      "import": "./dist/adapters/supabase/index.js"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "scripts": {
    "build": "bun run build:lib && bun run build:demo",
    "build:lib": "vite build && tsc -p tsconfig.build.json",
    "build:demo": "vite build --config demo/vite.config.ts",
    "dev": "vite --config demo/vite.config.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate": "bun run typecheck && bun run lint && bun run test && bun run build",
    "commitlint": "commitlint --edit",
    "prepare": "husky || true",
    "release": "semantic-release"
  },
  "peerDependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "@supabase/supabase-js": "^2.110.0",
    "react": ">=18 <20",
    "react-dom": ">=18 <20"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-s3": {
      "optional": true
    },
    "@aws-sdk/s3-request-presigner": {
      "optional": true
    },
    "@supabase/supabase-js": {
      "optional": true
    }
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "lucide-react": "^1.23.0",
    "react-selecto": "^1.26.3"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@supabase/supabase-js": "^2.110.0",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "semantic-release": "^25.0.5",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
