{
	"name": "@harryy/react-file-browser",
	"version": "1.1.1",
	"description": "A standalone, storage-agnostic React file manager component library.",
	"keywords": [
		"file-browser",
		"file-explorer",
		"file-manager",
		"r2",
		"react",
		"s3",
		"storage",
		"supabase",
		"typescript",
		"upload"
	],
	"homepage": "https://harryy2510.github.io/react-file-browser/",
	"bugs": {
		"url": "https://github.com/harryy2510/react-file-browser/issues"
	},
	"license": "MIT",
	"author": "Hariom Sharma",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/harryy2510/react-file-browser.git"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"type": "module",
	"sideEffects": false,
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./adapters/in-memory": {
			"types": "./dist/adapters/in-memory/index.d.ts",
			"import": "./dist/adapters/in-memory/index.js"
		},
		"./adapters/s3": {
			"types": "./dist/adapters/s3/index.d.ts",
			"import": "./dist/adapters/s3/index.js"
		},
		"./adapters/r2": {
			"types": "./dist/adapters/r2/index.d.ts",
			"import": "./dist/adapters/r2/index.js"
		},
		"./adapters/supabase": {
			"types": "./dist/adapters/supabase/index.d.ts",
			"import": "./dist/adapters/supabase/index.js"
		},
		"./theme": {
			"types": "./dist/theme/index.d.ts",
			"import": "./dist/theme/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "bun run build:lib && bun run build:demo",
		"build:lib": "vite build && tsc -p tsconfig.build.json",
		"build:demo": "vite build --config demo/vite.config.ts",
		"dev": "vite --config demo/vite.config.ts",
		"oxfmt": "oxfmt",
		"oxlint": "oxlint",
		"format": "bun run oxfmt --write .",
		"format:check": "bun run oxfmt --check .",
		"lint": "bun run oxlint --type-aware --type-check .",
		"test": "vitest run",
		"typecheck": "bun run lint",
		"validate": "bun run format:check && bun run lint && bun run test && bun run build",
		"commitlint": "commitlint --edit",
		"hooks:install": "lefthook install --reset-hooks-path",
		"hooks:validate": "lefthook run pre-commit --no-stage-fixed",
		"release": "semantic-release"
	},
	"dependencies": {
		"fflate": "^0.8.3",
		"lucide-react": "^1.23.0",
		"react-selecto": "^1.26.3"
	},
	"devDependencies": {
		"@aws-sdk/client-s3": "^3.1079.0",
		"@aws-sdk/s3-request-presigner": "^3.1079.0",
		"@commitlint/cli": "^21.2.0",
		"@commitlint/config-conventional": "^21.2.0",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/npm": "^13.1.5",
		"@supabase/supabase-js": "^2.110.0",
		"@tailwindcss/vite": "^4.3.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^26.1.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"jsdom": "^29.1.1",
		"lefthook": "^2.1.9",
		"oxfmt": "^0.57.0",
		"oxlint": "^1.72.0",
		"oxlint-tsgolint": "^0.24.0",
		"semantic-release": "^25.0.5",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3",
		"vite": "^8.1.3",
		"vitest": "^4.1.9"
	},
	"peerDependencies": {
		"@aws-sdk/client-s3": "^3.1079.0",
		"@aws-sdk/s3-request-presigner": "^3.1079.0",
		"@supabase/supabase-js": "^2.110.0",
		"react": ">=18 <20",
		"react-dom": ">=18 <20"
	},
	"peerDependenciesMeta": {
		"@aws-sdk/client-s3": {
			"optional": true
		},
		"@aws-sdk/s3-request-presigner": {
			"optional": true
		},
		"@supabase/supabase-js": {
			"optional": true
		}
	},
	"engines": {
		"node": ">=24"
	}
}
